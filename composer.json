{
    "name": "clcbws/laravel-database-lifecycle-suite",
    "version": "1.0.0",
    "description": "A complete database lifecycle suite for Laravel including index standardization, data drift detection, and reverse-engineering.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Ahtesham",
            "email": "ahtesham@clcbws.com",
            "homepage": "https://www.clcbws.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/console": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0",
        "laravel/pint": "^1.13",
        "phpstan/phpstan": "^1.10"
    },
    "suggest": {
        "clcbws/laravel-schema-sentinel": "Required for structural drift detection in the lifecycle scorecard (^1.6)."
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "lint": "vendor/bin/pint",
        "analyze": "vendor/bin/phpstan analyze"
    },
    "autoload": {
        "psr-4": {
            "Clcbws\\DatabaseLifecycleSuite\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Clcbws\\DatabaseLifecycleSuite\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Clcbws\\DatabaseLifecycleSuite\\DatabaseLifecycleSuiteServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
